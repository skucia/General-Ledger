# Secrets — never commit. Any .env or .env.<something> stays out;
# .env.example IS committed (it's the placeholder template).
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code local metadata (per-machine, not for sharing)
.claude/

# App-specific — keep the directory but exclude every file in it
uploads/*
!uploads/.gitkeep

# Database dumps — never commit (would expose all data + schema)
backups/
