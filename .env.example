# Copy this file to .env and fill in real values.
# .env is gitignored so secrets never leave your machine.

# --- Postgres connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=generalledger
DB_USER=gluser
DB_PASSWORD=<REDACTED>

# --- Session / app secrets ---
# Used to sign session cookies in Phase 2. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Uploads ---
UPLOAD_DIR=./uploads
