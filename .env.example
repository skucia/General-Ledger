# Copy this file to .env and fill in real values.
# .env is gitignored so secrets never leave your machine.
# IMPORTANT: the values below are placeholders, NOT working credentials.

# --- Postgres connection ---
#
# Two-database pattern (recommended): keep one database for test / sample
# data and another for real (live) data. Both databases share the same
# Postgres user, so DB_USER and DB_PASSWORD don't change between them —
# only DB_NAME does. To swap, comment the active DB_NAME line and
# uncomment the other.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=<your-db-name>_live           # active database (real data)
# DB_NAME=<your-db-name>_test         # historic test data — swap to inspect
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>        # use a strong, randomly-generated value

# --- Session / app secrets ---
# Used to sign session cookies in Phase 2. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Uploads ---
UPLOAD_DIR=./uploads
