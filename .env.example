# General Ledger — example environment file.
#
# Copy this to .env and fill in real values. NEVER commit .env (or any
# .env.<variant>) to git — .gitignore is configured to keep them out.
#
# Real config is loaded by app/config.py at startup. Missing required
# values fail loudly with a clear error rather than silently defaulting.

# --- Postgres connection ---

# Host where Postgres is reachable from the app process.
#   - Local dev (native uvicorn):              localhost
#   - Mode A (app in Docker, postgres on host):  host.docker.internal
#   - Mode B/C (app + postgres both in Docker): postgres
DB_HOST=localhost

# Postgres listener port. Stock Postgres = 5432.
DB_PORT=5432

# Database used by system scripts (run_migrations, create_admin).
# The running web app routes per-request to either _test or _live based
# on the user's choice at login, regardless of this value.
DB_NAME=generalledger_test

# Postgres role + password the app connects as.
DB_USER=gluser
DB_PASSWORD=replace-with-strong-password

# --- Session / cookie signing ---

# Used to sign the session cookie. MUST be at least 32 characters or the
# app will refuse to start. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-at-least-32-chars-from-the-command-above

# --- Login rate limiting ---

# Consecutive failed-password attempts that trigger a lockout for one
# (database, username) pair. Unknown-username attempts are NOT counted —
# avoids username enumeration via lockout side-channels.
LOGIN_MAX_ATTEMPTS=5

# How long the lockout lasts, in minutes.
LOGIN_LOCKOUT_MINUTES=15

# --- Uploads ---

# Where attachment files live on disk. Inside Docker we mount a named
# volume here; outside Docker any writable path works.
UPLOAD_DIR=./uploads
